# Copy to .env to override the defaults below.
# docker compose automatically reads .env.

# --- Site ---
WP_PORT=8080
WP_TITLE=Vivus AI
WP_DEBUG=1

# --- Admin account (created on first boot) ---
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@vivus.local

# --- Database ---
DB_NAME=vivus_wp
DB_USER=vivus
DB_PASSWORD=vivus_pass
DB_ROOT_PASSWORD=root_pass
